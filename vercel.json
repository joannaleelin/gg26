{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/staff/:name", "destination": "/staff/[name].html" },
    { "source": "/staff/:name/", "destination": "/staff/[name].html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
