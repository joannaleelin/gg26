{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/staff/:name", "destination": "/staff/_detail.html" },
    { "source": "/staff/:name/", "destination": "/staff/_detail.html" }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*\\.js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
